# -----------------------------------------------------------------------------
# Pfirsichfest Configuration Template
# -----------------------------------------------------------------------------
# Copy this file to '.env' and fill in your values.
# The '.env' file is ignored by Git to prevent leaking secrets.

# --- Core Platform Settings ---
# Google Cloud Project ID where the infrastructure will deploy
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Google Cloud Region/Zone
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_CLOUD_ZONE=us-central1-a

# --- Telegram Bot Settings ---
# Token obtained from @BotFather
TELEGRAM_BOT_TOKEN=123456789:your-token-here
# Your numerical Telegram User ID (find via @userinfobot) to restrict access
AUTHORIZED_USER_ID=123456789

# --- VPN Settings (Optional) ---
# If you don't use a VPN, leave ENABLE_VPN=false. 
# If true, the Spot VM will attempt to secure an OpenVPN tunnel before downloading.
ENABLE_VPN=false
VPN_USER=your-vpn-username
VPN_PASS=your-vpn-password
